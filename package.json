{
  "name": "ladder_rules_script",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build:all",
    "build:release": "bun run build_scripts/build-release.ts --clean",
    "build:release:clean": "bun run build_scripts/build-release.ts --clean",
    "build:release:prune": "bun run build_scripts/build-release.ts --clean --prune",
    "build:release:noclean": "bun run build_scripts/build-release.ts --no-clean",
    "generate:clients": "bun run build_scripts/generate-rules.ts --clean",
    "build:all": "bun run generate:clients && bun run build:release:clean"
  }
}
